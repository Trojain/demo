# 服务端口，前端默认代理到 http://localhost:3101
PORT=3101

# 前端行情推送地址。开发环境默认直连 ws://localhost:3101/ws
VITE_WS_BASE_URL=ws://localhost:3101/ws

# SQLite 数据文件位置，建议本地开发保留默认值
DATABASE_PATH=./data/web3-trading-tool.db

# 默认交易所，可选 okx 或 binance
DEFAULT_EXCHANGE=okx

# 是否启用真实下单。第一版建议保持 false，只允许模拟下单
ENABLE_REAL_TRADING=false

# 交易所 HTTP 代理。本机无法直连 OKX 或 Binance 时填写，例如 http://127.0.0.1:7897
EXCHANGE_HTTP_PROXY=

# OKX API 配置。真实下单开启时才需要填写
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_SIMULATED=true

# Binance API 配置。第一版预留
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance 是否切换到官方 Spot Test Network。开启后，公共行情、交易规则、真实下单、查单和私有推送都会切到测试网
BINANCE_USE_TESTNET=false

# 真实订单状态同步配置。后台会定时查询最近未终态的真实订单
REAL_ORDER_SYNC_INTERVAL_MS=15000
REAL_ORDER_SYNC_LOOKBACK_MINUTES=240
REAL_ORDER_SYNC_BATCH_SIZE=50

# 风控配置。单笔计价金额超过该值时拒绝生成触发事件
RISK_MAX_QUOTE_AMOUNT=1000

# 风控配置。行情超过该毫秒数未更新时拒绝生成触发事件
RISK_MAX_MARKET_AGE_MS=10000

# 风控配置。每日最大通过风控次数
RISK_DAILY_MAX_TRIGGER_COUNT=20

# 风控配置。每日最大通过风控计价金额
RISK_DAILY_MAX_QUOTE_AMOUNT=5000

# 风控配置。simulation_only 仅允许模拟交易，allow_real 允许真实交易
RISK_TRADING_MODE=simulation_only

# 模拟交易配置。模拟账户初始本金，按默认计价币种记录
SIMULATION_INITIAL_QUOTE_BALANCE=10000

# 模拟交易配置。模拟账户默认计价币种，当前建议使用 USDT
SIMULATION_QUOTE_CURRENCY=USDT
