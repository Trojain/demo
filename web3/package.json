{
  "name": "web3-trading-tool",
  "version": "0.1.0",
  "private": true,
  "description": "行情监控与半自动下单工具",
  "scripts": {
    "dev": "pnpm --parallel --filter @web3/server --filter @web3/web dev",
    "dev:web": "pnpm --filter @web3/web dev",
    "dev:server": "pnpm --filter @web3/server dev",
    "test:market-price": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/market-price-regression.test.ts",
    "test:market-service": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/market-service-regression.test.ts",
    "test:order-recovery": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/order-recovery-service.test.ts",
    "test:order-recovery-routes": "pnpm --filter @web3/server exec node --import tsx --test ./tests/order-recovery-routes.test.ts",
    "test:order-service": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/order-service.test.ts",
    "test:signal-service": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/signal-service.test.ts",
    "test:risk-service": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/risk-service.test.ts",
    "test:signal-risk-routes": "pnpm --filter @web3/server exec node --import tsx --test ./tests/signal-risk-routes.test.ts",
    "test:quality-analysis": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/quality-analysis-service.test.ts",
    "test:quality-analysis-routes": "pnpm --filter @web3/server exec node --import tsx --test ./tests/quality-analysis-routes.test.ts",
    "test:trade-fill-routes": "pnpm --filter @web3/server exec node --import tsx --test ./tests/trade-fill-routes.test.ts",
    "test:config-archive": "pnpm --filter @web3/server exec node --import tsx --test ../../tests/config-archive-service.test.ts",
    "test:config-archive-routes": "pnpm --filter @web3/server exec node --import tsx --test ./tests/config-archive-routes.test.ts",
    "typecheck": "pnpm --filter @web3/server typecheck && pnpm --filter @web3/web typecheck",
    "lint": "pnpm --filter @web3/server lint && pnpm --filter @web3/web lint"
  },
  "packageManager": "pnpm@10.13.1"
}
